<%= content_for :title, "Sources — Flyd" %>

<main class="mx-auto max-w-3xl px-6 py-10">
  <%= link_to "← Surface", root_path, class: "text-xs text-gray-500 hover:text-gray-950" %>
  <h1 class="mt-8 text-3xl font-medium"><%= @item.title %></h1>
  <p class="mt-3 text-sm text-gray-500">Evidence used by this scene.</p>

  <div class="mt-10 divide-y divide-gray-200 border-y border-gray-200">
    <% @sources.each do |source| %>
      <section class="py-5">
        <div class="text-[10px] uppercase tracking-[0.18em] text-gray-400"><%= source[:type] %>:<%= source[:id] %></div>
        <pre class="mt-3 overflow-x-auto whitespace-pre-wrap text-sm leading-6 text-gray-700"><%= JSON.pretty_generate(source[:record].respond_to?(:attributes) ? source[:record].attributes : source[:record]) %></pre>
      </section>
    <% end %>
  </div>
</main>
