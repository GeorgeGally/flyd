<%= content_for :title, "Sources — Flyd" %>

<div class="sys-shell sys-page">
  <header class="sys-masthead sys-reveal">
    <p class="sys-kicker">Surface · Sources</p>
    <h1 class="sys-display sys-display--md"><%= @item.title %></h1>
    <p class="sys-sub">Sources behind this scene.</p>
    <div class="sys-actions">
      <%= link_to "&larr; Surface".html_safe, root_path, class: "flyd-system-btn flyd-system-btn--ghost" %>
    </div>
  </header>

  <div class="sys-reveal" style="--d: 100ms">
    <% @sources.each do |source| %>
      <section class="sys-section">
        <div class="sys-section__head">
          <span class="flyd-system-label"><%= source.type %>:<%= source.id %></span>
        </div>
        <% record = source.record.respond_to?(:attributes) ? source.record.attributes : source.record.to_h %>
        <% content = record["content"].to_h %>
        <h2 class="mt-4 text-xl font-medium text-ink md:text-2xl"><%= content["title"].presence || record["title"].presence || source.type.humanize %></h2>
        <% if content["excerpt"].present? %><p class="mt-3 max-w-[68ch] whitespace-pre-wrap text-sm leading-6 text-muted"><%= content["excerpt"] %></p><% end %>
        <div class="sys-actions">
          <% if source.url.present? %><%= link_to "Read original", source.url, target: "_blank", rel: "noopener noreferrer", class: "flyd-system-btn flyd-system-btn--ghost" %><% end %>
          <% if source.discussion_url.present? %><%= link_to "Discussion", source.discussion_url, target: "_blank", rel: "noopener noreferrer", class: "flyd-system-btn flyd-system-btn--ghost" %><% end %>
        </div>
        <details class="mt-5 text-xs text-muted">
          <summary class="cursor-pointer font-mono hover:text-ink transition-colors">Raw source</summary>
          <pre class="mt-3 overflow-x-auto whitespace-pre-wrap border-t border-line pt-4 leading-5"><%= JSON.pretty_generate(record) %></pre>
        </details>
      </section>
    <% end %>
  </div>
</div>
