<div class="sys-shell sys-page">
  <header class="sys-masthead sys-reveal">
    <p class="sys-kicker">System · Index</p>
    <h2 class="sys-display">Projects</h2>
    <p class="sys-sub">
      <% if @active_projects.any? %>
        <%= pluralize(@active_projects.length, "active project") %><%= ", #{pluralize(@archived_projects.length, 'archived')}" if @archived_projects.any? %>
      <% else %>
        Persistent contexts Flyd reasons about.
      <% end %>
    </p>
    <div class="sys-actions">
      <%= link_to "New project", new_project_path, class: "flyd-system-btn flyd-system-btn--primary" %>
    </div>
  </header>

  <% if @active_projects.any? %>
    <div class="sys-ledger">
      <% @active_projects.each_with_index do |project, index| %>
        <%= link_to project_path(project), class: "sys-ledger__row sys-reveal", style: "--d: #{80 + index * 45}ms" do %>
          <span class="sys-ledger__index"><%= "%02d" % (index + 1) %></span>
          <span class="min-w-0">
            <span class="sys-ledger__title"><%= project.name %></span>
            <% if project.description.present? %>
              <span class="sys-ledger__desc"><%= truncate(project.description, length: 120) %></span>
            <% end %>
          </span>
          <span class="sys-ledger__meta">
            <%= time_ago_in_words(project.updated_at) %> ago
            <span class="sys-ledger__arrow" aria-hidden="true">&rarr;</span>
          </span>
        <% end %>
      <% end %>
    </div>

    <% if @archived_projects.any? %>
      <section class="sys-section">
        <div class="sys-section__head">
          <span class="flyd-system-label">Archived</span>
        </div>
        <div>
          <% @archived_projects.each do |project| %>
            <%= link_to project_path(project), class: "sys-ledger__row" do %>
              <span class="sys-ledger__index">&nbsp;</span>
              <span class="min-w-0">
                <span class="sys-ledger__title text-muted"><%= project.name %></span>
              </span>
              <span class="sys-ledger__meta">
                <span class="sys-status">Archived</span>
              </span>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>
  <% else %>
    <div class="sys-empty sys-reveal" style="--d: 120ms">
      <h3 class="sys-display sys-display--md">No projects yet.</h3>
      <p class="sys-sub">Create your first project to get started.</p>
      <div class="sys-actions">
        <%= link_to "Create Project", new_project_path, class: "flyd-system-btn flyd-system-btn--primary" %>
      </div>
    </div>
  <% end %>
</div>
