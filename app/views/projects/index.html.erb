<div class="max-w-3xl">
  <h2 class="text-2xl font-semibold text-ink mb-6">Projects</h2>

  <% if @active_projects.any? %>
    <div class="divide-y divide-line">
      <% @active_projects.each do |project| %>
        <%= link_to project_path(project), class: "flyd-system-card block py-4 group" do %>
          <div class="flex items-center justify-between gap-4">
            <div class="min-w-0">
              <h3 class="font-medium text-ink"><%= project.name %></h3>
              <% if project.description.present? %>
                <p class="text-sm text-muted mt-0.5"><%= truncate(project.description, length: 100) %></p>
              <% end %>
            </div>
            <span class="text-xs text-muted flex-shrink-0"><%= time_ago_in_words(project.updated_at) %> ago</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <p class="text-muted mb-5">No projects yet. Create your first project to get started.</p>
      <%= link_to "Create Project", new_project_path, class: "flyd-system-btn flyd-system-btn--primary px-5 py-2.5 rounded-sm" %>
    </div>
  <% end %>
</div>
