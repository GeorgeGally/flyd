<nav class="flex-1 overflow-y-auto px-2 py-2">
  <div class="flex items-center justify-between px-2 py-1 mb-1.5">
    <span class="flyd-system-label font-semibold">Projects</span>
    <%= link_to "New", new_project_path, class: "text-xs text-muted hover:text-ink transition-colors" %>
  </div>

  <% @active_projects.each do |project| %>
    <%= link_to project_path(project), class: "flex items-center gap-2 px-2 py-1.5 text-sm group" do %>
      <span class="flex-1 truncate text-ink"><%= project.name %></span>
      <% if project.last_activity_at %>
        <span class="text-xs text-muted flex-shrink-0"><%= time_ago_in_words(project.last_activity_at) %></span>
      <% end %>
    <% end %>
  <% end %>

  <% if @active_projects.empty? %>
    <p class="px-2 py-1 text-sm text-muted">No projects yet</p>
  <% end %>

  <% if @archived_projects&.any? %>
    <div class="mt-5">
      <span class="px-2 text-xs font-semibold text-muted uppercase">Archived</span>
      <% @archived_projects.each do |project| %>
        <%= link_to project_path(project), class: "flex items-center px-2 py-1 rounded text-sm text-muted hover:text-ink group" do %>
          <span class="flex-1 truncate"><%= project.name %></span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</nav>
