<%= form_with model: @project, class: "space-y-5" do |f| %>
  <% if @project.errors.any? %>
    <div class="px-4 py-2.5 border border-line">
      <h3 class="text-sm font-medium text-ink"><%= pluralize(@project.errors.count, "error") %> prohibited this project from being saved:</h3>
      <ul class="mt-1 text-sm text-muted list-disc list-inside">
        <% @project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "flyd-system-label mb-1.5 block" %>
    <%= f.text_field :name, class: "flyd-system-input", placeholder: "Project name", autofocus: true %>
  </div>

  <div>
    <%= f.label :description, class: "flyd-system-label mb-1.5 block" %>
    <%= f.text_area :description, rows: 3, class: "flyd-system-input resize-none", placeholder: "What is this project about?" %>
  </div>

  <div>
    <%= f.label :root_path, class: "flyd-system-label mb-1.5 block" %>
    <%= f.text_field :root_path, class: "flyd-system-input", placeholder: "~/path/to/project (optional)" %>
    <p class="text-xs text-muted mt-1.5">Maps auto-captures from this directory to this project.</p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "flyd-system-btn flyd-system-btn--primary px-4 py-2 rounded-sm cursor-pointer" %>
    <%= link_to "Cancel", @project.persisted? ? project_path(@project) : projects_path, class: "text-sm text-muted hover:text-ink transition-colors" %>
  </div>
<% end %>
