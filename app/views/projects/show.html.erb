<%= content_for :title, "#{@project.name} — Flyd" %>

<div class="sys-shell sys-page">
  <% if @project.archived? %>
    <div class="sys-strip sys-reveal">This project is archived.</div>
  <% end %>

  <header class="sys-masthead sys-reveal" style="--d: 40ms">
    <p class="sys-kicker"><%= @project.name %></p>
    <h2 class="sys-display">Here's where we are</h2>
    <% if @project.description.present? %>
      <p class="sys-sub"><%= @project.description %></p>
    <% end %>
    <div class="sys-actions">
      <%= link_to "Edit", edit_project_path(@project), class: "flyd-system-btn flyd-system-btn--ghost" %>
      <% if @project.archived? %>
        <%= button_to "Reactivate", reactivate_project_path(@project), method: :post, class: "flyd-system-btn flyd-system-btn--ghost", form: { class: "inline" } %>
      <% else %>
        <%= button_to "Archive", archive_project_path(@project), method: :post, class: "flyd-system-btn flyd-system-btn--ghost", form: { class: "inline" } %>
      <% end %>
      <%= button_to "Delete", project_path(@project), method: :delete, class: "flyd-system-btn flyd-system-btn--danger", data: { turbo_confirm: "Delete this project and all its data?" }, form: { class: "inline" } %>
    </div>
  </header>

  <% if @conversation = @project.active_conversation %>
    <section class="sys-section sys-reveal" style="--d: 100ms">
      <div class="sys-section__head">
        <span class="flyd-system-label">Current conversation</span>
        <%= link_to "Continue &rarr;".html_safe, project_conversation_path(@project, @conversation), class: "flyd-system-btn flyd-system-btn--ghost" %>
      </div>
      <div class="sys-transcript">
        <% @conversation.messages.ordered.last(3).each do |msg| %>
          <div class="sys-msg <%= msg.role == "user" ? "sys-msg--user" : "" %>">
            <div class="sys-msg__role"><%= msg.role == "user" ? "You" : "Flyd" %></div>
            <div class="sys-msg__body"><p><%= truncate(msg.content, length: 220) %></p></div>
          </div>
        <% end %>
        <% if @conversation.messages.none? %>
          <div class="sys-msg">
            <div class="sys-msg__role">Flyd</div>
            <div class="sys-msg__body"><p class="text-muted">No messages yet. Start the conversation!</p></div>
          </div>
        <% end %>
      </div>
    </section>
  <% else %>
    <section class="sys-section sys-reveal" style="--d: 100ms">
      <div class="sys-empty">
        <h3 class="sys-display sys-display--md">Start your first conversation</h3>
        <p class="sys-sub">Ask a question, describe a problem, or share what you're working on.</p>
        <div class="sys-actions">
          <%= link_to "New Conversation", project_conversations_path(@project), data: { turbo_method: :post }, class: "flyd-system-btn flyd-system-btn--primary" %>
        </div>
      </div>
    </section>
  <% end %>

  <% recent_decisions = @project.decisions.by_recency.limit(3) %>
  <% if recent_decisions.any? %>
    <section class="sys-section sys-reveal" style="--d: 160ms">
      <div class="sys-section__head">
        <span class="flyd-system-label">Recent decisions</span>
      </div>
      <div class="sys-transcript">
        <% recent_decisions.each do |decision| %>
          <div class="sys-msg">
            <div class="sys-msg__role"><%= time_ago_in_words(decision.created_at) %></div>
            <div class="sys-msg__body"><p><%= decision.content %></p></div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if recent_decisions.empty? && !@project.active_conversation %>
    <section class="sys-section sys-reveal" style="--d: 160ms">
      <div class="sys-section__head">
        <span class="flyd-system-label">Captures</span>
      </div>
      <div class="py-6">
        <% if @project.root_path.present? %>
          <p class="text-sm text-muted mb-4">Import existing captures from <span class="font-mono"><%= @project.root_path %></span></p>
          <%= link_to "Import Captures", project_path(@project), class: "flyd-system-btn flyd-system-btn--ghost" %>
        <% else %>
          <p class="text-sm text-muted">Set a root path in project settings to auto-link captures from your filesystem.</p>
        <% end %>
      </div>
    </section>
  <% end %>

  <% all_conversations = @project.conversations.ordered %>
  <% if all_conversations.any? %>
    <section class="sys-section sys-reveal" style="--d: 220ms">
      <div class="sys-section__head">
        <span class="flyd-system-label">Conversation history</span>
      </div>
      <div>
        <% all_conversations.each do |conv| %>
          <%= link_to project_conversation_path(@project, conv), class: "sys-ledger__row" do %>
            <span class="sys-ledger__index">&nbsp;</span>
            <span class="min-w-0">
              <span class="sys-ledger__title"><%= conv.messages.ordered.first&.content&.truncate(70) || "New conversation" %></span>
              <span class="sys-ledger__desc"><%= pluralize(conv.messages.count, "message") %> · <%= time_ago_in_words(conv.created_at) %> ago</span>
            </span>
            <span class="sys-ledger__meta">
              <% if conv.active? %>
                <span class="sys-status sys-status--active">Active</span>
              <% else %>
                <span class="sys-status">Archived</span>
              <% end %>
              <span class="sys-ledger__arrow" aria-hidden="true">&rarr;</span>
            </span>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
