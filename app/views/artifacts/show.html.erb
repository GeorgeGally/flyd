<%= content_for :title, "#{@artifact.title} — Flyd" %>

<div class="sys-shell sys-page">
  <header class="sys-masthead sys-reveal">
    <p class="sys-kicker"><%= @artifact.kind.humanize %> · <%= @artifact.status.humanize %></p>
    <h1 class="sys-display"><%= @artifact.title %></h1>
    <p class="sys-sub">Scene: <%= @artifact.scene.title %></p>
  </header>

  <article class="sys-reveal border-y border-ink py-8" style="--d: 100ms">
    <pre class="whitespace-pre-wrap font-sans text-sm leading-7 text-ink max-w-[72ch]"><%= @artifact.content %></pre>
  </article>

  <div class="sys-actions sys-reveal" style="--d: 160ms">
    <% if @artifact.conversation %>
      <%= link_to "Continue in Flyd", root_path(conversation_id: @artifact.conversation_id), class: "flyd-system-btn flyd-system-btn--ghost" %>
    <% else %>
      <%= link_to "Return to Flyd", root_path, class: "flyd-system-btn flyd-system-btn--ghost" %>
    <% end %>
    <% if @artifact.build %>
      <%= link_to "Build record", build_path(@artifact.build), class: "flyd-system-btn flyd-system-btn--ghost" %>
    <% end %>
  </div>
</div>
