<%= content_for :title, "#{@artifact.title} — Flyd" %>

<div class="mx-auto max-w-4xl py-12">
  <div class="flex items-center justify-between gap-4 text-[10px] uppercase tracking-[0.18em] text-gray-400">
    <span><%= @artifact.kind.humanize %></span>
    <span><%= @artifact.status.humanize %></span>
  </div>

  <h1 class="mt-5 text-4xl font-medium tracking-tight md:text-6xl"><%= @artifact.title %></h1>
  <p class="mt-4 text-sm text-gray-500">Scene: <%= @artifact.scene.title %></p>

  <article class="mt-10 border-y border-gray-200 py-8">
    <pre class="whitespace-pre-wrap font-sans text-sm leading-7 text-gray-800"><%= @artifact.content %></pre>
  </article>

  <div class="mt-8 flex items-center gap-4 text-sm">
    <% if @artifact.conversation %>
      <%= link_to "Continue in Flyd", root_path(conversation_id: @artifact.conversation_id), class: "underline decoration-gray-300 underline-offset-4" %>
    <% else %>
      <%= link_to "Return to Flyd", root_path, class: "underline decoration-gray-300 underline-offset-4" %>
    <% end %>
    <% if @artifact.build %>
      <%= link_to "Build record", build_path(@artifact.build), class: "underline decoration-gray-300 underline-offset-4" %>
    <% end %>
  </div>
</div>
