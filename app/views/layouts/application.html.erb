<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Flyd" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% if controller_name == "surfaces" %>
    <body class="h-dvh overflow-hidden bg-paper">
      <%= yield %>
    </body>
  <% elsif controller_name == "release_acceptance" %>
    <body class="min-h-dvh flyd-system-body">
      <%= yield %>
    </body>
  <% else %>
    <body class="h-dvh flex flex-col overflow-hidden flyd-system-body">
      <header class="sys-topbar">
        <%= link_to "flyd", root_path, class: "sys-topbar__wordmark text-ink" %>
        <nav class="sys-topbar__nav">
          <%= link_to "Surface", root_path %>
          <%= link_to "Projects", projects_path, aria: { current: (controller_name == "projects" ? "page" : nil) } %>
        </nav>
      </header>

      <main class="min-h-0 flex-1 overflow-y-auto">
        <%= yield %>
      </main>
    </body>
  <% end %>
</html>
