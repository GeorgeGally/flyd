<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Flyd" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% if controller_name == "surfaces" %>
    <body class="h-dvh overflow-hidden bg-paper">
      <%= yield %>
    </body>
  <% elsif controller_name == "release_acceptance" %>
    <body class="min-h-dvh flyd-system-body">
      <%= yield %>
    </body>
  <% else %>
    <body class="h-dvh flex flex-col overflow-hidden flyd-system-body md:flex-row">
      <aside class="flyd-system-sidebar hidden w-56 flex-shrink-0 flex-col md:flex">
        <div class="px-4 py-3.5 border-b border-line">
          <h1 class="text-base font-bold">
            <%= link_to "flyd", root_path, class: "text-ink hover:opacity-70 transition-opacity" %>
          </h1>
        </div>
        <%= render "projects/sidebar" %>
      </aside>

      <main class="min-w-0 flex-1 flex flex-col overflow-hidden">
        <header class="flex h-14 flex-shrink-0 items-center justify-between border-b border-line px-4 md:hidden">
          <%= link_to "flyd", root_path, class: "text-base font-bold text-ink" %>
          <nav class="flex items-center gap-5 text-xs">
            <%= link_to "Projects", projects_path, class: "text-muted hover:text-ink transition-colors" %>
            <%= link_to "New", new_project_path, class: "font-medium text-ink" %>
          </nav>
        </header>
        <div class="flex-1 overflow-y-auto px-4 py-5 sm:px-6 md:px-8 md:py-7">
          <%= yield %>
        </div>
      </main>
    </body>
  <% end %>
</html>
