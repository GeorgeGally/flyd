<%= content_for :title, "#{@conversation.owner_name} — Flyd" %>

<div class="flex h-full min-h-0 flex-col" data-controller="chat" data-chat-conversation-id-value="<%= @conversation.id %>">
  <header class="sys-shell w-full flex-shrink-0 pt-6 pb-5">
    <div class="flex items-start justify-between gap-6">
      <div class="min-w-0">
        <p class="sys-kicker">
          Conversation<% if @conversation.created_at %> · <%= time_ago_in_words(@conversation.created_at) %> ago<% end %>
        </p>
        <h2 class="sys-display sys-display--md truncate"><%= @conversation.owner_name %></h2>
      </div>
      <div class="sys-actions !mt-2 flex-shrink-0">
        <% if @project %>
          <%= link_to "Build this", project_conversation_builds_path(@project, @conversation), data: { turbo_method: :post }, class: "flyd-system-btn flyd-system-btn--primary" %>
          <%= link_to "Start New Chat", project_conversations_path(@project), data: { turbo_method: :post }, class: "flyd-system-btn flyd-system-btn--ghost" %>
          <%= link_to "Summary", project_path(@project), class: "flyd-system-btn flyd-system-btn--ghost" %>
        <% else %>
          <%= link_to "Surface", root_path(conversation_id: @conversation.id), class: "flyd-system-btn flyd-system-btn--ghost" %>
        <% end %>
      </div>
    </div>
  </header>

  <% visible_messages = @conversation.visible_messages %>
  <div class="min-h-0 flex-1 overflow-y-auto" data-chat-target="messages">
    <div class="sys-shell sys-transcript pb-8">
      <% if visible_messages.any? %>
        <% visible_messages.each do |message| %>
          <div class="sys-msg <%= message.role == "user" ? "sys-msg--user" : "" %>">
            <div class="sys-msg__role"><%= message.role == "user" ? "You" : "Flyd" %></div>
            <div class="sys-msg__body">
              <% if message.role == "assistant" %>
                <%= markdown(message.content) %>
              <% else %>
                <p><%= message.content %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="sys-empty">
          <h3 class="sys-display sys-display--md">Start a conversation</h3>
          <p class="sys-sub">Ask a question, describe a problem, or share what you're working on.</p>
        </div>
      <% end %>

      <div class="sys-msg hidden" data-chat-target="streamingMessage">
        <div class="sys-msg__role">Flyd</div>
        <div class="sys-msg__body">
          <div class="sys-thinking"><span class="sys-thinking__dot"></span><span>Thinking</span></div>
          <p data-chat-target="streamingContent"></p>
        </div>
      </div>
    </div>
  </div>

  <div class="sys-shell w-full flex-shrink-0 pb-5">
    <div class="sys-composer">
      <% message_path = @project ? project_conversation_messages_path(@project, @conversation) : conversation_messages_path(@conversation) %>
      <div class="pb-1"><span class="flyd-system-label">Message Flyd</span></div>
      <%= form_with url: message_path, method: :post, html: { data: { action: "submit->chat#submit" }, class: "flex items-end gap-4" } do |form| %>
        <div class="sr-only"><%= form.label :content, "Message" %></div>
        <%= form.text_area :content, rows: 1, placeholder: "Type a message...", data: { chat_target: "input", action: "keydown->chat#submitOnCommandEnter" }, aria: { label: "Message" }, class: "flyd-system-input min-h-[2.25rem] resize-none", style: "max-height: 140px" %>
        <button type="submit" class="flyd-system-btn flyd-system-btn--primary">Send</button>
      <% end %>
    </div>
  </div>
</div>
