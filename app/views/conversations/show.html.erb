<%= content_for :title, "#{@project.name} — Flyd" %>

<div class="flex flex-col h-full" data-controller="chat" data-chat-conversation-id-value="<%= @conversation.id %>">
  <div class="flex items-center justify-between pb-3 border-b border-gray-200 mb-3">
    <div>
      <h2 class="text-lg font-semibold text-gray-900"><%= @project.name %></h2>
      <% if @conversation.created_at %>
        <p class="text-xs text-gray-400"><%= time_ago_in_words(@conversation.created_at) %> ago</p>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Build this", project_conversation_builds_path(@project, @conversation), data: { turbo_method: :post }, class: "px-3 py-1.5 text-xs rounded-md bg-blue-600 text-white hover:bg-blue-700" %>
      <%= link_to "Start New Chat", project_conversations_path(@project), data: { turbo_method: :post }, class: "px-3 py-1.5 text-xs rounded-md border border-gray-300 hover:border-gray-400 text-gray-600" %>
      <%= link_to "Summary", project_path(@project), class: "px-3 py-1.5 text-xs rounded-md border border-gray-300 hover:border-gray-400 text-gray-600" %>
    </div>
  </div>

  <div class="flex-1 overflow-y-auto mb-4" data-chat-target="messages">
    <% if @conversation.messages.any? %>
      <% @conversation.messages.ordered.each do |message| %>
        <div class="flex <%= message.role == 'user' ? 'justify-end' : 'justify-start' %> mb-4">
          <div class="max-w-[80%] rounded-lg px-4 py-2 text-sm <%= message.role == 'user' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-900' %>">
            <% if message.role == 'assistant' %>
              <%= markdown(message.content) %>
            <% else %>
              <p><%= message.content %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center h-full text-center">
        <div class="max-w-md">
          <h3 class="text-lg font-medium text-gray-700 mb-2">Start a conversation</h3>
          <p class="text-sm text-gray-500">Ask a question, describe a problem, or share what you're working on.</p>
        </div>
      </div>
    <% end %>

    <div class="flex justify-start mb-4 hidden" data-chat-target="streamingMessage">
      <div class="max-w-[80%] rounded-lg px-4 py-2 bg-gray-100 text-gray-900 text-sm">
        <div class="flex items-center gap-2 mb-2">
          <div class="w-2 h-2 rounded-full bg-gray-400 animate-pulse"></div>
          <span class="text-xs text-gray-400">Thinking...</span>
        </div>
        <p data-chat-target="streamingContent"></p>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-200 pt-3">
    <%= form_with url: project_conversation_messages_path(@project, @conversation), method: :post, html: { data: { action: "submit->chat#submit" }, class: "flex items-end gap-2" } do |f| %>
      <div class="sr-only"><%= f.label :content, "Message" %></div>
      <%= f.text_area :content, rows: 1, placeholder: "Type a message...", data: { chat_target: "input" }, aria: { label: "Message" }, class: "flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent", style: "max-height: 120px" %>
      <button type="submit" class="px-4 py-2 rounded-lg bg-gray-900 text-white text-sm hover:bg-gray-800">
        Send
      </button>
    <% end %>
  </div>
</div>
