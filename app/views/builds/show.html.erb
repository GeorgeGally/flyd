<%= content_for :title, "Build — Flyd" %>

<div class="sys-shell sys-page">
  <header class="sys-masthead sys-reveal">
    <p class="sys-kicker"><%= @build.proposed? ? "Review before running" : "OpenCode execution" %></p>
    <h1 class="sys-display sys-display--md"><%= @build.scene&.title.presence || "Build proposal" %></h1>
    <p class="sys-sub"><%= @build.confirmation_summary %></p>
  </header>

  <dl class="sys-meta-grid sys-reveal text-sm" style="--d: 80ms">
    <div>
      <dt class="flyd-system-label">Project</dt>
      <dd class="mt-2 text-ink"><%= @build.project.name %></dd>
    </div>
    <div>
      <dt class="flyd-system-label">Working directory</dt>
      <dd class="mt-2 break-all font-mono text-[0.8rem] text-ink"><%= @build.project.root_path.presence || Dir.home %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="flyd-system-label">Instructions</dt>
      <dd class="mt-2 whitespace-pre-wrap leading-6 text-ink"><%= @build.instructions %></dd>
    </div>
  </dl>

  <% if @build.proposed? %>
    <div class="sys-actions sys-reveal" style="--d: 140ms">
      <%= button_to "Confirm build", confirm_build_path(@build), method: :post, class: "flyd-system-btn flyd-system-btn--primary cursor-pointer" %>
      <%= link_to "Return to Flyd", root_path(conversation_id: @build.conversation_id), class: "flyd-system-btn flyd-system-btn--ghost" %>
    </div>
    <p class="sys-composer__hint mt-4">Nothing has executed yet.</p>
  <% elsif @build.running? %>
    <div class="sys-section sys-reveal" style="--d: 140ms">
      <div class="sys-section__head">
        <span class="flyd-system-label">Status</span>
        <span class="sys-thinking"><span class="sys-thinking__dot"></span><span>Running</span></span>
      </div>
      <p class="py-5 text-sm text-muted">Flyd will return the outcome to the scene and conversation.</p>
      <%= link_to "Return to Flyd", root_path(conversation_id: @build.conversation_id), class: "flyd-system-btn flyd-system-btn--ghost" %>
    </div>
  <% elsif @build.artifact %>
    <div class="sys-section sys-reveal" style="--d: 140ms">
      <div class="sys-section__head">
        <span class="flyd-system-label"><%= @build.status.humanize %></span>
      </div>
      <p class="py-5 text-sm text-muted"><%= @build.outcome_summary %></p>
      <%= link_to "Open result", artifact_path(@build.artifact), class: "flyd-system-btn flyd-system-btn--primary" %>
    </div>
  <% else %>
    <div class="sys-section sys-reveal" style="--d: 140ms">
      <div class="sys-section__head">
        <span class="flyd-system-label"><%= @build.status.humanize %></span>
      </div>
      <p class="py-5 text-sm text-muted"><%= @build.outcome_summary %></p>
    </div>
  <% end %>
</div>
