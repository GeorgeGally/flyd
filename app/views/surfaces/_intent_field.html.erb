<div class="border-b border-gray-300 transition-all duration-300 focus-within:border-gray-950 focus-within:pb-5">
  <%= form.text_area field_name,
    rows: 1,
    placeholder: "Ask, tell, show…",
    aria: { label: "Tell Flyd what is happening" },
    class: "block w-full resize-none border-0 bg-transparent px-0 py-3 text-2xl font-normal leading-tight placeholder:text-gray-300 focus:outline-none focus:ring-0 md:text-4xl",
    data: {
      action: "focus->surface#focusIntent blur->surface#releaseIntent input->surface#resizeIntent keydown.esc->surface#releaseIntent",
      surface_target: "input",
      chat_target: (chat ? "input" : nil)
    }.compact %>

  <% unless chat %>
    <div class="mt-3 hidden group-focus-within:block">
      <%= form.text_area :clipboard,
        rows: 2,
        placeholder: "Paste longer material here…",
        class: "block w-full resize-none border-0 bg-gray-50 px-3 py-2 text-sm leading-5 text-gray-700 placeholder:text-gray-300 focus:outline-none focus:ring-0" %>
    </div>
  <% end %>

  <div class="flex items-center justify-between gap-4 pt-3 opacity-0 transition-opacity duration-200 group-focus-within:opacity-100">
    <span class="text-xs text-gray-400"><%= context_label %></span>
    <div class="flex items-center gap-3">
      <% unless chat %>
        <label class="cursor-pointer text-xs text-gray-500 hover:text-gray-950">
          Attach
          <%= form.file_field :files, multiple: true, accept: "image/*,audio/*,text/*,application/json,application/pdf", class: "sr-only" %>
        </label>
      <% end %>
      <%= form.submit "Send", class: "cursor-pointer rounded-full bg-gray-950 px-4 py-2 text-xs font-medium text-white" %>
    </div>
  </div>
</div>
