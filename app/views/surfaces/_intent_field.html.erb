<div class="flyd-intent-field">
  <%= form.text_area field_name,
    rows: 1,
    placeholder: "Ask, tell, show…",
    aria: { label: "Tell Flyd what is happening" },
    class: "flyd-intent-field__input",
    data: {
      action: [
        "focus->surface#focusIntent",
        "blur->surface#releaseIntent",
        "input->surface#resizeIntent",
        "keydown.esc->surface#releaseIntent",
        (chat ? "keydown->chat#submitOnCommandEnter" : "keydown->surface#submitOnCommandEnter")
      ].compact.join(" "),
      surface_target: "input",
      chat_target: (chat ? "input" : nil)
    }.compact %>

  <% unless chat %>
    <div class="mt-3">
      <%= form.text_area :clipboard,
        rows: 2,
        placeholder: "Paste longer material here…",
        class: "block w-full resize-none border-0 bg-ink/[0.03] px-3 py-2 text-sm leading-5 text-ink placeholder:text-muted/50 focus:outline-none focus:ring-0" %>
    </div>
  <% end %>

  <div class="flyd-intent-field__tools">
    <span class="text-xs text-muted"><%= context_label %></span>
    <div class="flex items-center gap-3">
      <% unless chat %>
        <label class="flyd-intent-field__icon" aria-label="Attach evidence" title="Attach evidence">
          +
          <%= form.file_field :files, multiple: true, accept: "image/*,audio/*,text/*,application/json,application/pdf", class: "sr-only" %>
        </label>
      <% end %>
      <%= form.submit "↑", class: "flyd-intent-field__submit", aria: { label: "Send to Flyd" }, title: "Send to Flyd" %>
    </div>
  </div>
</div>
