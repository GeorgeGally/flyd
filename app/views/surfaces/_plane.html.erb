<% visible_items = surface.items.reject { |item| %w[dismissed collapsed].include?(item.state) } %>
<% surface_mode = (surface.metadata["surface_mode"].presence || "quiet").to_s %>
<% composition = {
     "decision" => "comparison-wall",
     "investigation" => "working-scene",
     "action" => "working-scene",
     "conversation" => "working-scene",
     "monitoring" => "editorial-focus",
     "discovery" => "poster-deck",
     "quiet" => "editorial-focus"
   }.fetch(surface_mode, "editorial-focus") %>
<% conversation_scene = active_conversation&.scenes&.order(updated_at: :desc)&.first %>
<% if active_conversation %>
  <% visible_items = visible_items.reject { |item| item.renderer == "conversation" || item.scene_id == conversation_scene&.id }.first(2) %>
<% else %>
  <% visible_items = visible_items.first(surface_mode == "quiet" ? 1 : 3) %>
<% end %>
<% project_ids = visible_items.flat_map(&:context_refs).filter_map do |ref|
     type = ref["type"] || ref[:type]
     id = ref["id"] || ref[:id]
     id if type == "project"
   end.uniq %>
<% surface_projects = Project.where(id: project_ids).index_by(&:id) %>

<section id="surface_plane"
         class="surface-composition surface-composition--<%= composition %> <%= 'surface-composition--solo' if !active_conversation && visible_items.one? %>"
         data-surface-target="plane"
         data-surface-id="<%= surface.id %>"
         data-surface-mode="<%= surface_mode %>"
         data-surface-composition="<%= composition.tr('-', '_') %>"
         data-surface-focus-key="<%= active_conversation ? "conversation:#{active_conversation.id}" : surface.focus_item_id %>"
         <% if surface_mode == "discovery" %>data-action="touchstart->surface#startSwipe touchend->surface#endSwipe"<% end %>
         data-surface-intention="<%= surface.current_intention %>">
  <% if active_conversation %>
    <article id="surface_semantic_conversation_<%= active_conversation.id %>"
             class="surface-item surface-object relative z-20 w-full"
             data-surface-target="item"
             data-item-key="conversation:<%= active_conversation.id %>"
             data-host="surface"
             data-role="focus"
             data-depth="foreground"
             data-state="presented"
             data-renderer="conversation"
             data-outgoing-behaviours=""
             data-incoming-behaviours="join">
      <%= render "surfaces/active_conversation", conversation: active_conversation, scene: conversation_scene %>
    </article>
  <% end %>

  <% visible_items.each_with_index do |item, position| %>
    <% dominant = !active_conversation && item.item_key == surface.focus_item_id %>
    <% role = dominant ? "focus" : "support" %>
    <% project_ref = item.context_refs.find { |ref| (ref["type"] || ref[:type]) == "project" } %>
    <% project_id = project_ref && (project_ref["id"] || project_ref[:id]) %>
    <% context_project = surface_projects[project_id.to_i] if project_id %>
    <% renderer = SurfaceRenderers::Registry.fetch(item.renderer) %>
    <% runtime_binding = RuntimeTasks::BindingPresenter.call(item) if renderer[:runtime] %>
    <% outgoing = item.relationships.select { |relationship| (relationship["from"] || relationship[:from]).to_s == item.item_key.to_s }.map { |relationship| relationship["behaviour"] || relationship[:behaviour] }.uniq %>
    <% incoming = item.relationships.select { |relationship| (relationship["to"] || relationship[:to]).to_s == item.item_key.to_s }.map { |relationship| relationship["behaviour"] || relationship[:behaviour] }.uniq %>
    <% semantic_dom_id = "surface_semantic_#{Digest::SHA256.hexdigest(item.item_key.to_s)[0, 16]}" %>

    <article id="<%= semantic_dom_id %>"
             class="surface-item surface-object relative <%= role == 'focus' ? 'z-20' : 'z-0' %>"
             data-surface-target="item"
             data-item-key="<%= item.item_key %>"
             data-host="surface"
             data-role="<%= role %>"
             data-position="<%= position %>"
             data-depth="<%= item.depth %>"
             data-state="<%= item.state %>"
             data-renderer="<%= item.renderer %>"
             data-variant="<%= item.metadata["variant"] %>"
             data-outgoing-behaviours="<%= outgoing.join(' ') %>"
             data-incoming-behaviours="<%= incoming.join(' ') %>"
             <% if surface_mode == "discovery" %>data-action="click->surface#focusObject keydown->surface#focusObject" tabindex="0"<% end %>>
      <%= render renderer[:partial], item: item, context_project: context_project, dominant: dominant, binding: runtime_binding %>
    </article>
  <% end %>
</section>
