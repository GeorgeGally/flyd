<div class="border-l border-line pl-6 py-2">
  <div class="mb-5 flex items-center justify-between text-xs text-muted">
    <span>Current work · <%= conversation.owner_name %></span>
    <% history_path = conversation.project ? project_conversation_path(conversation.project, conversation) : conversation_path(conversation) %>
    <%= link_to "Full history", history_path, class: "hover:text-ink transition-colors" %>
  </div>

  <h2 class="max-w-3xl text-3xl font-medium md:text-5xl text-ink"><%= scene&.title.presence || conversation.summary.presence || "Continue where we left off" %></h2>
  <% if scene&.desired_outcome.present? %>
    <p class="mt-4 max-w-2xl text-sm leading-6 text-muted"><%= scene.desired_outcome %></p>
  <% end %>

  <div class="mt-8 max-w-3xl space-y-6" data-chat-target="messages">
    <% conversation.visible_messages.last(8).each do |message| %>
      <div class="<%= message.role == 'user' ? 'pl-8' : '' %>">
        <div class="mb-1 text-xs text-muted"><%= message.role.humanize %></div>
        <div class="text-sm leading-6 text-ink"><%= message.role == "assistant" ? markdown(message.content) : simple_format(message.content) %></div>
      </div>
    <% end %>
    <div class="hidden" data-chat-target="streamingMessage">
      <div class="mb-1 text-xs text-muted">Assistant</div>
      <div class="text-sm leading-6 text-ink" data-chat-target="streamingContent"></div>
    </div>
  </div>

  <% if conversation.project %>
    <div class="mt-8 flex items-center gap-4 text-xs">
      <%= button_to "Build", project_conversation_builds_path(conversation.project, conversation), method: :post, class: "font-medium underline decoration-line underline-offset-4 hover:decoration-ink text-ink" %>
    </div>
  <% end %>
</div>
