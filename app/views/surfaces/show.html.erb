<%= content_for :title, "Flyd" %>
<%= turbo_stream_from "flyd_surface" %>
<% surface_mode = (@surface.metadata["surface_mode"].presence || "quiet").to_s %>
<% focus_item = @surface.items.find { |item| item.item_key == @surface.focus_item_id } || @surface.items.first %>
<% context_ref = Array(focus_item&.context_refs).first %>
<% context_type = context_ref && (context_ref["type"] || context_ref[:type]) %>
<% context_id = context_ref && (context_ref["id"] || context_ref[:id]) %>
<% context_name = case context_type
   when "project" then Project.find_by(id: context_id)&.name
   when "context" then ::Context.find_by(id: context_id)&.name
   end %>
<% intent_expanded = @conversation.present? || @intent&.status == "clarification_required" %>

<div class="flyd-stage"
     data-controller="surface<%= ' chat' if @conversation %>"
     data-surface-mode="<%= surface_mode %>"
     <% if intent_expanded %>data-intent-active="true"<% end %>
     <% if @conversation %>data-chat-conversation-id-value="<%= @conversation.id %>"<% end %>>
  <header class="flyd-stage__header">
    <div class="flyd-wordmark">
      <%= link_to "flyd", root_path %>
      <button type="button"
              class="flyd-wordmark__intent"
              aria-label="Open Flyd input"
              title="Open Flyd input"
              data-surface-target="launcher"
              data-action="surface#openIntent"></button>
    </div>
    <%= link_to "System", projects_path, class: "flyd-system-link" %>
  </header>

  <main class="flyd-stage__scene">
    <%= render "surfaces/plane", surface: @surface, active_conversation: @conversation %>
  </main>

  <footer class="flyd-stage__context">
    <span><%= context_name.present? ? "#{context_type.humanize}: #{context_name}" : "Flyd" %></span>
    <span aria-hidden="true">•</span>
    <span><%= surface_mode.humanize %></span>
  </footer>

  <section class="flyd-intent-tray" data-surface-target="intent" aria-hidden="<%= !intent_expanded %>">
    <div class="flyd-intent-tray__inner">
      <button type="button"
              class="flyd-intent-tray__close"
              aria-label="Close Flyd input"
              title="Close Flyd input"
              data-action="surface#closeIntent">×</button>
      <% if @conversation %>
        <% message_path = @conversation.project ? project_conversation_messages_path(@conversation.project, @conversation) : conversation_messages_path(@conversation) %>
        <%= form_with url: message_path, scope: :message, method: :post, html: { data: { action: "submit->chat#submit" }, class: "group" } do |form| %>
          <%= render "surfaces/intent_field", form: form, field_name: :content, context_label: "Continuing #{@conversation.owner_name}", chat: true %>
        <% end %>
      <% else %>
        <%= form_with url: intents_path, scope: :intent, method: :post, class: "group" do |form| %>
          <%= form.hidden_field :project_id, value: @preferred_project.id if @preferred_project %>
          <%= form.hidden_field :modality, value: "text" %>
          <%= render "surfaces/intent_field", form: form, field_name: :text, context_label: (@preferred_project ? "Context: #{@preferred_project.name}" : "Flyd will assign context after understanding the outcome."), chat: false %>
        <% end %>
      <% end %>

      <% if @intent&.status == "clarification_required" %>
        <div class="mt-6 max-h-64 overflow-y-auto border-t border-gray-200 pt-5">
          <p class="text-sm text-gray-700">This may relate to:</p>
          <div class="mt-3 flex flex-wrap gap-3 text-xs">
            <% @intent.context_candidates.each do |candidate| %>
              <%= form_with url: intent_context_corrections_path(@intent), method: :post do %>
                <%= hidden_field_tag "corrected_contexts[][type]", candidate["type"] %>
                <%= hidden_field_tag "corrected_contexts[][id]", candidate["id"] %>
                <%= hidden_field_tag "corrected_contexts[][name]", candidate["name"] %>
                <%= submit_tag candidate["name"], class: "rounded-full border border-gray-300 px-4 py-2 hover:border-gray-950" %>
              <% end %>
            <% end %>
            <%= form_with url: intent_context_corrections_path(@intent), method: :post do %>
              <%= hidden_field_tag :reason, "No persistent context" %>
              <%= submit_tag "No persistent context", class: "rounded-full border border-gray-300 px-4 py-2 hover:border-gray-950" %>
            <% end %>
          </div>

          <details class="mt-5 text-sm">
            <summary class="cursor-pointer text-gray-500 hover:text-gray-950">Create a temporary context</summary>
            <%= form_with url: intent_contexts_path(@intent), scope: :context, method: :post, class: "mt-4 grid gap-3 sm:grid-cols-[1fr_auto]" do |form| %>
              <%= form.text_field :name, required: true, placeholder: "Context name", class: "border-b border-gray-300 bg-transparent px-0 py-2 focus:border-gray-950 focus:outline-none" %>
              <%= form.submit "Create", class: "rounded-full bg-gray-950 px-4 py-2 text-xs font-medium text-white" %>
              <%= form.text_area :description, rows: 2, placeholder: "What is this context?", class: "border-b border-gray-200 bg-transparent px-0 py-2 text-sm focus:border-gray-950 focus:outline-none sm:col-span-2" %>
            <% end %>
          </details>
        </div>
      <% end %>
    </div>
  </section>
</div>
