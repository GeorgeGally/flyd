<%= content_for :title, "Flyd" %>

<div class="min-h-screen bg-white text-gray-950"
     data-controller="surface<%= ' chat' if @conversation %>"
     <% if @conversation %>data-chat-conversation-id-value="<%= @conversation.id %>"<% end %>>
  <div class="mx-auto flex min-h-screen max-w-7xl flex-col px-6 py-6 md:px-10 md:py-8">
    <header class="flex items-center justify-between">
      <%= link_to "flyd", root_path, class: "text-sm font-semibold tracking-tight" %>
      <%= link_to "System", projects_path, class: "text-[10px] uppercase tracking-[0.18em] text-gray-300 hover:text-gray-700" %>
    </header>

    <section class="mt-14 md:mt-20" data-surface-target="intent">
      <% if @conversation %>
        <%= form_with url: project_conversation_messages_path(@conversation.project, @conversation), scope: :message, method: :post, html: { data: { action: "submit->chat#submit" }, class: "group" } do |form| %>
          <%= render "surfaces/intent_field", form: form, field_name: :content, context_label: "Context: #{@conversation.project.name}", chat: true %>
        <% end %>
      <% else %>
        <%= form_with url: intents_path, scope: :intent, method: :post, class: "group" do |form| %>
          <%= form.hidden_field :project_id, value: @preferred_project.id if @preferred_project %>
          <%= render "surfaces/intent_field", form: form, field_name: :text, context_label: (@preferred_project ? "Context: #{@preferred_project.name}" : "Flyd will infer the context."), chat: false %>
        <% end %>
      <% end %>

      <% if @conversation %>
        <div class="mt-8 max-w-3xl border-l border-gray-200 pl-5">
          <div class="mb-5 flex items-center justify-between text-[10px] uppercase tracking-[0.18em] text-gray-400">
            <span><%= @conversation.project.name %></span>
            <%= link_to "Full history", project_conversation_path(@conversation.project, @conversation), class: "hover:text-gray-900" %>
          </div>
          <div class="flex flex-col-reverse gap-5" data-chat-target="messages">
            <% @conversation.messages.order(created_at: :desc).limit(8).reverse.each do |message| %>
              <div>
                <div class="mb-1 text-[10px] uppercase tracking-[0.15em] text-gray-400"><%= message.role %></div>
                <div class="text-sm leading-6 text-gray-800"><%= message.role == "assistant" ? markdown(message.content) : simple_format(message.content) %></div>
              </div>
            <% end %>
            <div class="hidden" data-chat-target="streamingMessage">
              <div class="mb-1 text-[10px] uppercase tracking-[0.15em] text-gray-400">assistant</div>
              <div class="text-sm leading-6 text-gray-800" data-chat-target="streamingContent"></div>
            </div>
          </div>
        </div>
      <% end %>
    </section>

    <section class="relative mt-14 grid flex-1 gap-5 md:grid-cols-12" data-surface-target="plane">
      <% @surface.items.each do |item| %>
        <% dominant = item.id == @surface.focus_item_id %>
        <article class="surface-item transition-all duration-500 <%= dominant ? 'md:col-span-8' : 'md:col-span-4' %>" data-surface-target="item" data-depth="<%= item.depth %>">
          <div class="flex h-full min-h-52 flex-col justify-between border-t border-gray-950 py-5 <%= dominant ? 'md:min-h-96' : '' %>">
            <div>
              <div class="mb-8 flex items-center justify-between text-[10px] uppercase tracking-[0.18em] text-gray-400">
                <span><%= item.intent %></span>
                <% if item.project %><span><%= item.project.name %></span><% end %>
              </div>
              <h2 class="max-w-3xl text-2xl font-medium leading-tight md:text-4xl"><%= item.title %></h2>
              <p class="mt-5 max-w-2xl text-sm leading-6 text-gray-600 md:text-base"><%= truncate(item.summary, length: dominant ? 360 : 180) %></p>
            </div>
            <% if item.project %>
              <div class="mt-10 text-xs"><%= link_to "Discuss", root_path(project_id: item.project.id), class: "font-medium underline decoration-gray-300 underline-offset-4 hover:decoration-gray-950" %></div>
            <% end %>
          </div>
        </article>
      <% end %>
    </section>
  </div>
</div>
