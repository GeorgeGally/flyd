<section class="directed-surface working-scene" data-runtime-task-key="<%= binding.task.task_key %>">
  <div class="working-scene__primary">
    <div class="flex items-center justify-between gap-6">
      <span class="surface-label"><%= binding.task.project.name %></span>
      <span class="surface-label"><%= binding.status_label %></span>
    </div>
    <h2 class="working-scene__title mt-8 max-w-5xl font-medium leading-[1.01]"><%= item.title %></h2>
    <p class="mt-7 max-w-3xl text-xl leading-9 text-gray-600"><%= binding.task.outcome_summary.presence || item.summary %></p>
  </div>

  <div class="working-scene__secondary">
    <section class="border-t border-gray-950 pt-6">
      <div class="surface-label">Returned work</div>
      <div class="mt-5 space-y-4">
        <% binding.verified_artifacts.each do |artifact| %>
          <%= link_to task_artifact_path(artifact.artifact_key), class: "flex items-center justify-between gap-4 border-b border-gray-300 pb-3 text-sm" do %>
            <span><%= artifact.title %></span>
            <span class="text-gray-400"><%= artifact.kind %></span>
          <% end %>
        <% end %>
      </div>
    </section>
    <p class="mt-8 text-xs text-gray-400">Completed <%= l(binding.task.completed_at, format: :long) if binding.task.completed_at %> · revision <%= binding.task.revision %></p>
  </div>
</section>
