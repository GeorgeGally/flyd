<section class="directed-surface working-scene" data-runtime-task-key="<%= binding.task.task_key %>">
  <div class="working-scene__primary">
    <div class="flex items-center justify-between gap-6">
      <span class="surface-label"><%= binding.task.project.name %></span>
      <span class="surface-label"><%= binding.status_label %></span>
    </div>
    <h2 class="working-scene__title mt-8 max-w-5xl font-medium leading-[1.02]"><%= item.title %></h2>
    <p class="mt-7 max-w-3xl text-lg leading-8 text-gray-600"><%= item.summary %></p>

    <div class="mt-12 border-t border-gray-950">
      <% binding.workers.each do |worker| %>
        <% assignment = binding.assignments.find { |candidate| candidate.id == worker.task_assignment_id } %>
        <% worker_actions = Array(item.actions).select { |action| action.dig("payload", "worker_key") == worker.worker_key } %>
        <section class="grid gap-5 border-b border-gray-300 py-6 md:grid-cols-[1fr_auto] md:items-start">
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <span class="text-lg font-medium"><%= assignment&.title || worker.adapter.humanize %></span>
              <span class="surface-label"><%= worker.status.humanize %></span>
            </div>
            <p class="mt-3 max-w-2xl text-sm leading-6 text-gray-600"><%= worker.error_summary.presence || assignment&.instructions.to_s.truncate(260) %></p>
            <p class="mt-3 text-xs text-gray-400">Observed <%= time_ago_in_words(worker.last_observed_at || worker.updated_at) %> ago · <%= worker.adapter %></p>
          </div>

          <% if binding.controls_enabled? %>
            <div class="flex flex-wrap gap-4 text-xs">
              <% worker_actions.select { |action| %w[stop_worker retry_worker replace_worker].include?(action["id"]) }.each do |action| %>
                <%= button_to action["label"], surface_item_action_path(item, action_id: action["id"]), method: :post, class: "border-b border-gray-950 py-1 font-medium" %>
              <% end %>
            </div>
          <% end %>

          <% redirect_action = worker_actions.find { |action| action["id"] == "redirect_worker" } %>
          <% if redirect_action && binding.controls_enabled? %>
            <%= form_with url: surface_item_action_path(item, action_id: "redirect_worker"), method: :post, class: "md:col-span-2" do |form| %>
              <%= form.label :instruction, "Redirect this worker", class: "surface-label" %>
              <div class="mt-2 flex items-end gap-3">
                <%= form.text_field :instruction, required: true, maxlength: 4000, placeholder: "Change the next move", class: "min-w-0 flex-1 border-0 border-b border-gray-400 bg-transparent px-0 py-2 text-sm focus:border-gray-950 focus:ring-0" %>
                <%= form.submit redirect_action["label"].presence || "Redirect", class: "border-b border-gray-950 py-2 text-sm font-medium" %>
              </div>
            <% end %>
          <% end %>
        </section>
      <% end %>
    </div>
  </div>

  <div class="working-scene__secondary">
    <section class="editorial-panel">
      <div class="surface-label">Assignments</div>
      <ol class="mt-5 space-y-5">
        <% binding.assignments.each do |assignment| %>
          <li class="grid grid-cols-[1fr_auto] gap-4 text-sm">
            <span><%= assignment.title %></span>
            <span class="text-gray-400"><%= assignment.status.humanize %></span>
          </li>
        <% end %>
      </ol>
    </section>
    <% if binding.stale? %>
      <section class="editorial-panel border-gray-300">
        <div class="surface-label">Read only</div>
        <p class="mt-5 text-sm leading-6 text-gray-600">The runtime is at revision <%= binding.task.revision %>. Flyd is replacing this scene before accepting another command.</p>
      </section>
    <% end %>
  </div>
</section>
