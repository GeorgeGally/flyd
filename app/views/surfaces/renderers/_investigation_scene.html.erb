<section class="editorial-object working-scene">
  <div class="working-scene__primary">
    <div>
      <div class="editorial-object__eyebrow">Investigation</div>
      <h2 class="working-scene__title mt-7 max-w-4xl font-medium leading-[1.02] tracking-tight"><%= item.title %></h2>
      <p class="mt-7 max-w-2xl text-base leading-7 text-gray-600 md:text-lg"><%= item.summary %></p>
    </div>

    <div class="mt-12 max-w-4xl border-t border-gray-950 pt-6">
      <div class="editorial-object__eyebrow">Next question</div>
      <p class="mt-4 text-2xl font-medium leading-tight md:text-4xl"><%= item.metadata["next_question"] %></p>
      <div class="mt-8 flex flex-wrap gap-4 text-xs">
        <% item.actions.each do |action| %>
          <% action_id = action["id"] || action[:id] %>
          <% if action_id == "investigate" %>
            <%= button_to action["label"] || "Investigate", surface_item_action_path(item, action_id: action_id), method: :post, params: { payload: action["payload"] || {} }, class: "bg-gray-950 px-5 py-3 font-medium text-white focus:outline-none focus:ring-2 focus:ring-gray-950 focus:ring-offset-2" %>
          <% elsif action_id == "discuss" %>
            <%= button_to action["label"] || "Think together", surface_item_action_path(item, action_id: action_id), method: :post, params: { payload: action["payload"] || {} }, class: "border border-gray-300 px-5 py-3 font-medium hover:border-gray-950 focus:outline-none focus:ring-2 focus:ring-gray-950 focus:ring-offset-2" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="working-scene__secondary">
    <section class="editorial-panel">
      <div class="editorial-object__eyebrow">What we know</div>
      <div class="mt-4 divide-y divide-gray-200">
        <% Array(item.metadata["known"]).each do |fact| %>
          <p class="py-4 text-sm leading-6"><%= fact %></p>
        <% end %>
      </div>
    </section>

    <section class="editorial-panel border-gray-300">
      <div class="editorial-object__eyebrow">What remains uncertain</div>
      <div class="mt-4 divide-y divide-gray-200">
        <% Array(item.metadata["unknown"]).each do |unknown| %>
          <p class="py-4 text-sm leading-6 text-gray-600"><%= unknown %></p>
        <% end %>
      </div>
    </section>
  </div>
</section>
