<% options = Array(item.metadata["options"]) %>
<% recommended_id = options.first && options.first["id"].to_s %>

<section class="directed-surface decision-field" style="--option-count: <%= [options.length, 1].max %>">
  <div class="decision-field__thesis">
    <div class="surface-label">Decision</div>
    <h2 class="mt-7 max-w-xl text-4xl font-medium leading-[1.02] md:text-6xl"><%= item.title %></h2>
    <p class="mt-7 max-w-lg text-base leading-7 text-gray-600"><%= item.summary %></p>

    <% if item.metadata["recommendation"].present? %>
      <div class="mt-10 max-w-lg border-t border-gray-950 pt-5">
        <div class="surface-label">Flyd recommends</div>
        <p class="mt-3 text-lg font-medium leading-7"><%= item.metadata["recommendation"] %></p>
      </div>
    <% end %>

    <%= render "surfaces/actions", item: item, context_project: context_project, actions: item.actions.reject { |action| (action["id"] || action[:id]) == "choose" } %>
  </div>

  <div class="decision-field__options" aria-label="Decision options">
    <% options.each_with_index do |option, index| %>
      <% action = item.actions.find { |candidate| (candidate["id"] || candidate[:id]) == "choose" && (candidate.dig("payload", "option_id") || candidate.dig(:payload, :option_id)).to_s == option["id"].to_s } %>
      <% recommended = option["id"].to_s == recommended_id %>
      <article class="decision-option" data-recommended="<%= recommended %>">
        <div>
          <div class="flex items-center justify-between gap-4">
            <span class="surface-label"><%= recommended ? "Recommended" : "Alternative" %></span>
            <span class="text-xs text-gray-300"><%= format("%02d", index + 1) %></span>
          </div>
          <div class="mt-5 h-px w-12 <%= recommended ? 'bg-amber-300' : 'bg-gray-200' %>"></div>
          <h3 class="mt-10 text-3xl font-medium leading-[1.05] md:text-4xl"><%= option["label"] %></h3>
          <% if option["description"].present? %>
            <p class="mt-6 text-sm leading-7 text-gray-600"><%= option["description"] %></p>
          <% end %>
        </div>

        <% if action %>
          <div class="mt-10">
            <% if recommended %>
              <%= button_to "Accept", surface_item_action_path(item, action_id: "choose"), method: :post, params: { payload: action["payload"] }, class: "inline-flex min-w-32 items-center justify-between gap-8 bg-amber-300 px-5 py-3 text-xs font-medium text-gray-950 hover:bg-amber-200 focus:outline-none focus:ring-2 focus:ring-gray-950 focus:ring-offset-2" %>
            <% else %>
              <%= button_to "Choose", surface_item_action_path(item, action_id: "choose"), method: :post, params: { payload: action["payload"] }, class: "inline-flex min-w-32 items-center justify-between gap-8 border border-gray-300 bg-white px-5 py-3 text-xs font-medium text-gray-950 hover:border-gray-950 focus:outline-none focus:ring-2 focus:ring-gray-950 focus:ring-offset-2" %>
            <% end %>
          </div>
        <% end %>
      </article>
    <% end %>
  </div>
</section>
