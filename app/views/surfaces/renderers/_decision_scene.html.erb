<% options = Array(item.metadata["options"]) %>
<% recommended_id = item.metadata["recommendation"].present? && options.first && options.first["id"].to_s %>
<% attachment_ids = options.filter_map { |option| option["attachment_id"] } %>
<% attachments = IntentAttachment.available.where(id: attachment_ids).index_by { |attachment| attachment.id.to_s } %>
<% recommended_action = item.actions.find do |candidate|
     (candidate["id"] || candidate[:id]) == "choose" &&
       (candidate.dig("payload", "option_id") || candidate.dig(:payload, :option_id)).to_s == recommended_id
   end %>

<section class="directed-surface decision-field" style="--option-count: <%= [options.length, 1].max %>">
  <div class="decision-field__thesis">
    <div>
      <div class="surface-label">Decision</div>
      <h2 class="mt-7 max-w-xl text-4xl font-medium leading-[1.02] md:text-6xl"><%= item.title %></h2>
      <p class="mt-7 max-w-lg text-base leading-7 text-gray-600"><%= item.summary %></p>

      <% if item.metadata["recommendation"].present? %>
        <div class="mt-10 max-w-lg">
          <div class="h-px w-8 bg-gray-400"></div>
          <p class="mt-5 text-lg leading-7 text-gray-700"><%= item.metadata["recommendation"] %></p>
        </div>
      <% end %>
    </div>

    <div class="decision-field__actions">
      <% if recommended_action %>
        <%= button_to surface_item_action_path(item, action_id: "choose"), method: :post, params: { option_id: recommended_id }, class: "decision-field__accept" do %>
          <span>Accept</span><span aria-hidden="true">→</span>
        <% end %>
      <% end %>
      <%= render "surfaces/actions", item: item, context_project: context_project, actions: item.actions.reject { |action| (action["id"] || action[:id]) == "choose" } %>
    </div>
  </div>

  <div class="decision-field__options" aria-label="Decision options">
    <% options.each_with_index do |option, index| %>
      <% action = item.actions.find { |candidate| (candidate["id"] || candidate[:id]) == "choose" && (candidate.dig("payload", "option_id") || candidate.dig(:payload, :option_id)).to_s == option["id"].to_s } %>
      <% recommended = option["id"].to_s == recommended_id %>
      <% attachment = attachments[option["attachment_id"].to_s] %>
      <article class="decision-option" data-recommended="<%= recommended %>">
        <div class="decision-option__heading">
          <span class="surface-label"><%= recommended ? "Recommended" : "Alternative" %></span>
        </div>

        <div class="decision-option__object">
          <% if attachment&.safe_inline? %>
            <%= image_tag intent_attachment_path(attachment), alt: option["label"], class: "decision-option__image" %>
          <% else %>
            <div class="decision-option__text">
              <h3><%= option["label"] %></h3>
              <% if option["description"].present? %><p><%= option["description"] %></p><% end %>
            </div>
          <% end %>
        </div>

        <div class="decision-option__caption">
          <div>
            <h3><%= option["label"] %></h3>
            <% if option["description"].present? %><p><%= option["description"] %></p><% end %>
          </div>
          <% if action && !recommended %>
            <%= button_to "Choose", surface_item_action_path(item, action_id: "choose"), method: :post, params: { option_id: option["id"] }, class: "decision-option__choose" %>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>
