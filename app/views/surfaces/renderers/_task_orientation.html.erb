<section class="directed-surface working-scene" data-runtime-task-key="<%= binding.task.task_key %>">
  <div class="working-scene__primary">
    <div class="flex items-center justify-between gap-6">
      <span class="surface-label"><%= binding.task.project.name %></span>
      <span class="surface-label"><%= binding.status_label %></span>
    </div>

    <h2 class="working-scene__title mt-8 max-w-5xl font-medium leading-[1.02]"><%= item.title %></h2>
    <p class="mt-7 max-w-3xl text-lg leading-8 text-gray-600"><%= item.summary %></p>

    <div class="mt-12 border-t border-gray-950 pt-7">
      <div class="surface-label">Intended outcome</div>
      <p class="mt-4 max-w-4xl text-2xl font-medium leading-tight md:text-4xl"><%= binding.task.intended_outcome %></p>
    </div>

    <% if binding.stale? %>
      <p class="mt-8 text-sm text-gray-500">The runtime moved to revision <%= binding.task.revision %>. Controls remain read-only while Flyd refreshes this scene.</p>
    <% end %>
  </div>

  <div class="working-scene__secondary">
    <section class="editorial-panel">
      <div class="surface-label">Success means</div>
      <ol class="mt-5 space-y-4 text-sm leading-6">
        <% Array(binding.task.success_criteria).each_with_index do |criterion, index| %>
          <li class="grid grid-cols-[2rem_1fr] gap-3"><span class="text-gray-400"><%= index + 1 %></span><span><%= criterion %></span></li>
        <% end %>
      </ol>
    </section>

    <section class="editorial-panel border-gray-300">
      <div class="surface-label">Repository</div>
      <p class="mt-5 break-all text-sm leading-6 text-gray-600"><%= binding.task.project.root_path %></p>
      <p class="mt-3 text-xs text-gray-400">Task revision <%= binding.task.revision %></p>
    </section>
  </div>
</section>
