{
  "name": "@radarboy/flyd",
  "version": "0.1.0",
  "description": "flyd — continuous personal coding agent",
  "type": "module",
  "bin": {
    "flyd": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild.mjs",
    "dev": "tsx src/index.ts",
    "export-state": "tsx src/export-state.ts",
    "core": "tsx src/server.ts start",
    "core:stop": "tsx src/server.ts stop",
    "core:status": "tsx src/server.ts status",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@tobilu/qmd": "^2.5.3",
    "commander": "^12.0.0",
    "dotenv": "^17.4.2",
    "openai": "^4.0.0",
    "pg": "^8.22.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GeorgeGally/flyd.git"
  },
  "license": "MIT"
}
