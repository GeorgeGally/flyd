<div class="max-w-md mx-auto mt-16">
  <h2 class="text-2xl font-bold text-gray-900 mb-2">Welcome to Flyd</h2>
  <p class="text-gray-500 mb-6">Configure your LLM provider to start chatting. Your keys are stored in <code class="text-xs bg-gray-100 px-1 rounded">~/.flyd/config.json</code>.</p>

  <% if notice %>
    <div class="p-3 mb-4 rounded-md bg-green-50 border border-green-200 text-sm text-green-700"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="p-3 mb-4 rounded-md bg-red-50 border border-red-200 text-sm text-red-700"><%= alert %></div>
  <% end %>

  <%= form_with url: settings_path, method: :patch, class: "space-y-4" do |f| %>
    <% unless Flyd::KeyLoader.get("OPENAI_API_KEY") %>
      <div>
        <%= f.label :openai_api_key, "OpenAI API Key", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :openai_api_key, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent font-mono", placeholder: "sk-..." %>
        <p class="text-xs text-gray-400 mt-1">Get one at <a href="https://platform.openai.com/api-keys" class="text-blue-600 hover:text-blue-800">platform.openai.com</a></p>
      </div>
    <% else %>
      <div class="p-3 rounded-md bg-green-50 border border-green-200 flex items-center gap-2">
        <span class="text-green-600 text-sm">OpenAI API key is configured.</span>
      </div>
    <% end %>

    <% unless Flyd::KeyLoader.get("ANTHROPIC_API_KEY") %>
      <div>
        <%= f.label :anthropic_api_key, "Anthropic API Key (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :anthropic_api_key, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent font-mono", placeholder: "sk-ant-..." %>
        <p class="text-xs text-gray-400 mt-1">Get one at <a href="https://console.anthropic.com/" class="text-blue-600 hover:text-blue-800">console.anthropic.com</a></p>
      </div>
    <% end %>

    <%= f.submit "Save and Continue", class: "w-full px-4 py-2 rounded-md bg-gray-900 text-white text-sm hover:bg-gray-800 cursor-pointer" %>
  <% end %>
</div>
